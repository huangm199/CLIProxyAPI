# Leapcell environment variable template
#
# Add these in Leapcell -> Env Variables

DEPLOY=cloud
WRITABLE_PATH=/tmp
TZ=Asia/Shanghai

# Optional: enable localhost-only management routes with a runtime password.
# MANAGEMENT_PASSWORD=replace-with-a-strong-management-password

# Optional: persistent backends. Use one of these if you need durable auth/config.
#
# Postgres token store
# PGSTORE_DSN=postgresql://user:pass@host:5432/cliproxy
# PGSTORE_SCHEMA=public
# PGSTORE_LOCAL_PATH=/tmp
#
# Git-backed config store
# GITSTORE_GIT_URL=https://github.com/your-org/cli-proxy-config.git
# GITSTORE_GIT_USERNAME=git-user
# GITSTORE_GIT_TOKEN=ghp_xxx
# GITSTORE_GIT_BRANCH=main
# GITSTORE_LOCAL_PATH=/tmp
#
# Object storage token store
# OBJECTSTORE_ENDPOINT=https://s3.your-cloud.example.com
# OBJECTSTORE_BUCKET=cli-proxy-config
# OBJECTSTORE_ACCESS_KEY=your_access_key
# OBJECTSTORE_SECRET_KEY=your_secret_key
# OBJECTSTORE_LOCAL_PATH=/tmp
